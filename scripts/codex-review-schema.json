{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["scores", "weighted_average", "concerns"],
  "additionalProperties": false,
  "properties": {
    "scores": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["dimension", "weight", "score", "evidence"],
        "additionalProperties": false,
        "properties": {
          "dimension": { "type": "string" },
          "weight": { "type": "integer", "minimum": 0, "maximum": 4 },
          "score": { "type": "integer", "minimum": 1, "maximum": 10 },
          "evidence": { "type": "string" }
        }
      }
    },
    "weighted_average": { "type": "number", "minimum": 1, "maximum": 10 },
    "concerns": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
